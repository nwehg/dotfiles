{
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["tray", "battery", "backlight", "custom/mealie"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["custom/spotify", "custom/cava", "pulseaudio", "network", "clock"],
    // Modules configuration
     "hyprland/workspaces": {
         "disable-scroll": false,
         "all-outputs": false,
         "warp-on-scroll": false,
         "format": "{name} {icon}",
         "format-icons": {
             "1": "  ΎΚσ  ",
             "2": "  ΎΘΚ  ",
             "3": "  ΎΕι  ",
             "4": "  ΎΖδ  ",
             "6": "  ΎΓΖ  ",
             "8": "  ΎΓΕ  ",
             "9": "  ΎΘΩ  ",
            "10": "  ΎΗ╝  ",
             "urgent": "  ΎΒς  ",
             "default": "  ΎΗΤ  ",
             "focused": "  ΎΕΣ  "
         }
     },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
				"interval": 1,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%H:%M:%S - %Y-%m-%d}"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        "format-good": "ΎΚΒ",
        "format-full": "ΎΚΑ",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },

    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "format-ethernet": "{ipaddr}/{cidr} ΎηΨ",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "≤░ζθ {icon}ΎΛΦ {format_source}",
        "format-muted": "≤░ζθ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
		"custom/spotify": {
		    "exec": "/usr/bin/python3 ~/.config/waybar/mediaplayer.py --player spotify",
		    "format": "{}  ΎΗ╝",
		    "return-type": "json",
		    "on-click": "playerctl --player=spotify play-pause",
		    "on-click-middle": "playerctl --player=spotify previous",
				"on-click-right": "playerctl --player=spotify next"
		},
		"custom/cava": {
			"exec": "~/.config/waybar/cava.sh"
		},
		"custom/mealie": {
			"exec": "~/.config/scripts/mealie.sh",
			"format": "≤░Κγ  {}",
			"on-click": "xdg-open $(jq -r .url ~/mealiecreds.json)"
		}
}
